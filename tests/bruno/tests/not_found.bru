meta {
  name: Not Found
  type: http
}

get {
  url: {{base_url}}/nonexistent
}

tests {
  test("Status is 404", function() {
    expect(res.getStatus()).to.eql(404);
  });
  test("Body matches contract", function() {
    expect(res.getBody()).to.eql({ error: { code: "endpoint_not_found" } });
  });
}
