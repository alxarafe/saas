meta {
  name: Login Invalid Credentials
  type: http
}

post {
  url: {{base_url}}/auth/login
  body: json
}

body:json {
  {
    "email": "wrong@example.com",
    "password": "wrong"
  }
}

tests {
  test("Status is 401", function() {
    expect(res.getStatus()).to.eql(401);
  });
  test("Error code is invalid_credentials", function() {
    expect(res.getBody()).to.eql({ error: { code: "invalid_credentials" } });
  });
}
