meta {
  name: Login Success
  type: http
}

post {
  url: {{base_url}}/auth/login
  body: json
}

body:json {
  {
    "email": "admin@example.com",
    "password": "secret"
  }
}

tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.eql(200);
  });
  test("Has token", function() {
    expect(res.getBody().data.token).to.be.a.string;
  });
}
